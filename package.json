{
  "name": "manga-box-pc",
  "version": "1.0.0",
  "description": "A local manga reader desktop app built with Electron + Vue 3",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && vue-tsc --noEmit",
    "preview": "electron-vite preview",
    "typecheck": "vue-tsc --noEmit",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "keywords": [
    "manga",
    "reader",
    "electron",
    "vue"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.16",
    "electron-store": "^8.2.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^20.11.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "less": "^4.6.4",
    "typescript": "^5.3.3",
    "vite": "^5.0.0",
    "vue-tsc": "^2.0.0"
  },
  "build": {
    "appId": "com.mangabox.pc",
    "productName": "MangaBox",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.icns"
    }
  }
}
